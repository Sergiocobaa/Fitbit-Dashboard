# Google OAuth — copia estos valores desde Google Cloud Console
GOOGLE_CLIENT_ID=tu_client_id_aqui
GOOGLE_CLIENT_SECRET=tu_client_secret_aqui

# Tu refresh token obtenido en el OAuth Playground
GOOGLE_REFRESH_TOKEN=tu_refresh_token_aqui

# URL base de tu app (en local: http://localhost:3000)
NEXTAUTH_URL=http://localhost:3000

# Secreto aleatorio para firmar cookies (genera uno en: https://generate-secret.vercel.app)
NEXTAUTH_SECRET=cambia_esto_por_un_secreto_aleatorio
